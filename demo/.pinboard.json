{
  "presets": [
    {
      "name": "Frontend Team",
      "paths": [
        { "path": "packages/frontend/src", "alias": "Frontend Source" },
        { "path": "packages/shared", "alias": "Shared Lib" },
        "docs/frontend"
      ]
    },
    {
      "name": "Backend Team",
      "paths": [
        { "path": "packages/backend", "alias": "Backend Service" },
        { "path": "packages/api", "alias": "REST API" },
        { "path": "packages/shared", "alias": "Shared Lib" }
      ]
    },
    {
      "name": "Docs & Scripts",
      "paths": ["docs", "scripts", ".github"]
    }
  ]
}
