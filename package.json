{
  "name": "pinboard",
  "publisher": "daanrosendal",
  "displayName": "Pinboard - Pin Files and Folders",
  "description": "Pin files and folders to a persistent Explorer sidebar panel with global/workspace scopes, drag reordering, workspace presets, and quick actions",
  "version": "0.0.23",
  "license": "MIT",
  "icon": "assets/icon.png",
  "keywords": [
    "pin",
    "pinned",
    "pinning",
    "favorite",
    "favorites",
    "favourite",
    "favourites",
    "bookmark",
    "bookmarks",
    "shortcut",
    "shortcuts",
    "quick access",
    "tree",
    "tree view",
    "file tree",
    "files",
    "folders",
    "directories",
    "directory",
    "explorer",
    "sidebar",
    "workspace",
    "global",
    "persistent",
    "navigation",
    "organize",
    "organise",
    "file management",
    "project navigation",
    "access"
  ],
  "galleryBanner": {
    "color": "#111111",
    "theme": "dark"
  },
  "markdown": "github",
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/DaanRosendal/pinboard.git"
  },
  "homepage": "https://github.com/DaanRosendal/pinboard#readme",
  "bugs": {
    "url": "https://github.com/DaanRosendal/pinboard/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:pinboard"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Pinboard",
      "properties": {
        "pinboard.scope": {
          "type": "string",
          "enum": [
            "global",
            "workspace"
          ],
          "default": "global",
          "enumDescriptions": [
            "Pinned items persist across all workspaces.",
            "Pinned items are scoped to the current workspace."
          ],
          "description": "Where pinned items are stored."
        },
        "pinboard.autoReveal": {
          "type": "boolean",
          "default": true,
          "description": "Auto-reveal the active file in the Pinboard tree when it falls under a pinned folder."
        },
        "pinboard.labelStyle": {
          "type": "string",
          "enum": ["name", "relativePath"],
          "default": "name",
          "enumDescriptions": [
            "Display the file or folder name only.",
            "Display the path relative to the workspace root. Falls back to folder name if outside all workspace folders."
          ],
          "description": "How pinned root items are labeled when no alias is set."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "pinboard",
          "name": "Pinboard"
        }
      ]
    },
    "commands": [
      { "command": "pinboard.addFolder",           "category": "Pinboard", "title": "Add File or Folder",            "icon": "$(add)" },
      { "command": "pinboard.refresh",             "category": "Pinboard", "title": "Refresh",                      "icon": "$(refresh)" },
      { "command": "pinboard.unpinFolder",         "category": "Pinboard", "title": "Unpin Folder",                 "icon": "$(close)" },
      { "command": "pinboard.unpinFile",           "category": "Pinboard", "title": "Unpin File",                   "icon": "$(close)" },
      { "command": "pinboard.openInNewWindow",     "category": "Pinboard", "title": "Open in New Window",           "icon": "$(multiple-windows)" },
      { "command": "pinboard.moveUp",              "category": "Pinboard", "title": "Move Up",                      "icon": "$(arrow-up)" },
      { "command": "pinboard.moveDown",            "category": "Pinboard", "title": "Move Down",                    "icon": "$(arrow-down)" },
      { "command": "pinboard.alreadyOpen",         "category": "Pinboard", "title": "Already Open in This Window",  "icon": "$(window-active)" },
      { "command": "pinboard.pinFromExplorer",     "category": "Pinboard", "title": "Pin to Pinboard" },
      { "command": "pinboard.switchToWorkspace",   "category": "Pinboard", "title": "Switch to Workspace Scope",    "icon": "$(globe)" },
      { "command": "pinboard.switchToGlobal",      "category": "Pinboard", "title": "Switch to Global Scope",       "icon": "$(root-folder)" },
      { "command": "pinboard.openToSide",          "category": "Pinboard", "title": "Open to the Side",             "icon": "$(split-horizontal)" },
      { "command": "pinboard.revealInOS",          "category": "Pinboard", "title": "Reveal in File Manager" },
      { "command": "pinboard.openInTerminal",      "category": "Pinboard", "title": "Open in Integrated Terminal" },
      { "command": "pinboard.findInFolder",        "category": "Pinboard", "title": "Find in Folder..." },
      { "command": "pinboard.copyPath",            "category": "Pinboard", "title": "Copy Path" },
      { "command": "pinboard.copyRelativePath",    "category": "Pinboard", "title": "Copy Relative Path" },
      { "command": "pinboard.rename",              "category": "Pinboard", "title": "Rename" },
      { "command": "pinboard.deleteItem",          "category": "Pinboard", "title": "Delete" },
      { "command": "pinboard.newFile",             "category": "Pinboard", "title": "New File..." },
      { "command": "pinboard.newFolder",           "category": "Pinboard", "title": "New Folder..." },
      { "command": "pinboard.renamePinnedFolder",  "category": "Pinboard", "title": "Rename" },
      { "command": "pinboard.deletePinnedFolder",  "category": "Pinboard", "title": "Delete" },
      { "command": "pinboard.applyPreset",         "category": "Pinboard", "title": "Apply Workspace Preset...",    "icon": "$(list-selection)" },
      { "command": "pinboard.setAlias",            "category": "Pinboard", "title": "Set Alias…" },
      { "command": "pinboard.editAlias",           "category": "Pinboard", "title": "Edit Alias…" },
      { "command": "pinboard.removeAlias",         "category": "Pinboard", "title": "Remove Alias" },
      { "command": "pinboard.toggleLabelStyle",     "category": "Pinboard", "title": "Toggle Label Style (Folder Name / Relative Path)" },
      { "command": "pinboard.openWorkspaceConfig", "category": "Pinboard", "title": "Open Workspace Config" }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pinboard.switchToWorkspace",
          "when": "view == pinboard && pinboard.isGlobalScope",
          "group": "navigation@1"
        },
        {
          "command": "pinboard.switchToGlobal",
          "when": "view == pinboard && !pinboard.isGlobalScope",
          "group": "navigation@1"
        },
        {
          "command": "pinboard.addFolder",
          "when": "view == pinboard",
          "group": "navigation@2"
        },
        {
          "command": "pinboard.refresh",
          "when": "view == pinboard",
          "group": "navigation@3"
        },
        {
          "command": "pinboard.applyPreset",
          "when": "view == pinboard && !pinboard.isGlobalScope && pinboard.hasPresets",
          "group": "navigation@0"
        }
      ],
      "view/item/context": [
        { "command": "pinboard.openInNewWindow", "when": "view == pinboard && viewItem =~ /^pinnedFolder/ && !(viewItem =~ /^pinnedFolderActive/)", "group": "inline@1" },
        { "command": "pinboard.alreadyOpen",     "when": "view == pinboard && viewItem =~ /^pinnedFolderActive/",                                   "group": "inline@1" },
        { "command": "pinboard.unpinFolder",     "when": "view == pinboard && viewItem =~ /^pinnedFolder/",                                         "group": "inline@2" },
        { "command": "pinboard.unpinFile",       "when": "view == pinboard && viewItem =~ /^pinnedFileRoot/",                                       "group": "inline@1" },

        { "command": "pinboard.newFile",   "when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem == pinnedDirectory)", "group": "1_new@1" },
        { "command": "pinboard.newFolder", "when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem == pinnedDirectory)", "group": "1_new@2" },

        { "command": "pinboard.revealInOS",     "when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem =~ /^pinnedFileRoot/ || viewItem == pinnedFile || viewItem == pinnedDirectory)", "group": "2_reveal@1" },
        { "command": "pinboard.openInTerminal", "when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem == pinnedDirectory)",                                                           "group": "2_reveal@2" },
        { "command": "pinboard.findInFolder",   "when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem == pinnedDirectory)",                                                           "group": "2_reveal@3" },

        { "command": "pinboard.openToSide",    "when": "view == pinboard && (viewItem =~ /^pinnedFileRoot/ || viewItem == pinnedFile)",              "group": "3_open@1" },
        { "command": "pinboard.openInNewWindow","when": "view == pinboard && viewItem =~ /^pinnedFolder/ && !(viewItem =~ /^pinnedFolderActive/)",   "group": "3_open@2" },
        { "command": "pinboard.moveUp",        "when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem =~ /^pinnedFileRoot/)",         "group": "3_open@3" },
        { "command": "pinboard.moveDown",      "when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem =~ /^pinnedFileRoot/)",         "group": "3_open@4" },

        { "command": "pinboard.copyPath",         "when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem =~ /^pinnedFileRoot/ || viewItem == pinnedFile || viewItem == pinnedDirectory)", "group": "4_copy@1" },
        { "command": "pinboard.copyRelativePath", "when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem =~ /^pinnedFileRoot/ || viewItem == pinnedFile || viewItem == pinnedDirectory)", "group": "4_copy@2" },

        { "command": "pinboard.rename",            "when": "view == pinboard && (viewItem == pinnedFile || viewItem == pinnedDirectory)",                    "group": "5_modify@1" },
        { "command": "pinboard.deleteItem",        "when": "view == pinboard && (viewItem == pinnedFile || viewItem == pinnedDirectory)",                    "group": "5_modify@2" },
        { "command": "pinboard.renamePinnedFolder","when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem =~ /^pinnedFileRoot/)",             "group": "5_modify@1" },
        { "command": "pinboard.deletePinnedFolder","when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem =~ /^pinnedFileRoot/)",             "group": "5_modify@2" },
        { "command": "pinboard.setAlias",          "when": "view == pinboard && (viewItem =~ /^pinnedFolder/ || viewItem =~ /^pinnedFileRoot/) && !(viewItem =~ /Aliased/)", "group": "5_modify@3" },
        { "command": "pinboard.editAlias",         "when": "view == pinboard && viewItem =~ /Aliased/",                                                     "group": "5_modify@3" },
        { "command": "pinboard.removeAlias",       "when": "view == pinboard && viewItem =~ /Aliased/",                                                     "group": "5_modify@4" }
      ],
      "commandPalette": [
        { "command": "pinboard.setAlias",            "when": "false" },
        { "command": "pinboard.editAlias",           "when": "false" },
        { "command": "pinboard.removeAlias",         "when": "false" },
        { "command": "pinboard.pinFromExplorer",     "when": "false" },
        { "command": "pinboard.alreadyOpen",         "when": "false" },
        { "command": "pinboard.unpinFolder",         "when": "false" },
        { "command": "pinboard.unpinFile",           "when": "false" },
        { "command": "pinboard.openInNewWindow",     "when": "false" },
        { "command": "pinboard.moveUp",              "when": "false" },
        { "command": "pinboard.moveDown",            "when": "false" },
        { "command": "pinboard.openToSide",          "when": "false" },
        { "command": "pinboard.revealInOS",          "when": "false" },
        { "command": "pinboard.openInTerminal",      "when": "false" },
        { "command": "pinboard.findInFolder",        "when": "false" },
        { "command": "pinboard.copyPath",            "when": "false" },
        { "command": "pinboard.copyRelativePath",    "when": "false" },
        { "command": "pinboard.rename",              "when": "false" },
        { "command": "pinboard.deleteItem",          "when": "false" },
        { "command": "pinboard.newFile",             "when": "false" },
        { "command": "pinboard.newFolder",           "when": "false" },
        { "command": "pinboard.renamePinnedFolder",  "when": "false" },
        { "command": "pinboard.deletePinnedFolder",  "when": "false" }
      ],
      "explorer/context": [
        {
          "command": "pinboard.pinFromExplorer",
          "when": "explorerResourceIsFolder",
          "group": "navigation@100"
        },
        {
          "command": "pinboard.pinFromExplorer",
          "when": "!explorerResourceIsFolder && resourceScheme == file",
          "group": "navigation@100"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": "**/.pinboard.json",
        "url": "./schemas/pinboard.schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.23.0",
    "eslint": "^9.9.1",
    "npm-run-all": "^4.1.5",
    "sinon": "^21.0.2",
    "typescript": "^5.5.4"
  }
}
