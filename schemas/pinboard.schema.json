{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pinboard Presets",
  "type": "object",
  "properties": {
    "presets": {
      "type": "array",
      "description": "Named pinboard presets for this workspace.",
      "items": {
        "type": "object",
        "required": ["name", "paths"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name shown in the preset picker."
          },
          "paths": {
            "type": "array",
            "description": "Relative paths (from workspace root) to pin.",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": ["presets"],
  "additionalProperties": false
}
