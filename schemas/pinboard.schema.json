{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pinboard Presets",
  "type": "object",
  "properties": {
    "presets": {
      "type": "array",
      "description": "Named pinboard presets for this workspace.",
      "items": {
        "type": "object",
        "required": ["name", "paths"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name shown in the preset picker."
          },
          "paths": {
            "type": "array",
            "description": "Paths to pin (relative to workspace root). Each entry is a plain path string or an object with a path and optional alias.",
            "items": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["path"],
                  "properties": {
                    "path": { "type": "string", "description": "Relative path to pin." },
                    "alias": { "type": "string", "description": "Custom display name shown in the Pinboard panel." }
                  },
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": ["presets"],
  "additionalProperties": false
}
